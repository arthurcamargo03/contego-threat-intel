# Template das variáveis de ambiente.
# Copie este arquivo para `.env` e preencha com os valores reais:
#   cp .env.example .env
# O `.env` NÃO é versionado (está no .gitignore) — as chaves reais nunca vão pro git.

# --- AlienVault OTX (obrigatório) ---
# Chave da API do OTX. Crie conta gratuita em https://otx.alienvault.com
# e pegue a chave em Settings > API Integration.
OTX_API_KEY=

# --- Anthropic Claude (opcional) ---
# Usada só para o resumo em linguagem natural. Se ficar em branco, a app funciona
# normalmente, apenas sem a seção "Resumo IA" (degradação graciosa).
ANTHROPIC_API_KEY=

# Modelo do resumo. Configurável via env para trocar sem mexer no código.
# Um modelo rápido/barato basta para o briefing.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Configuração local (opcional; têm defaults sensatos no código) ---
# Caminho do arquivo SQLite do histórico.
DATABASE_PATH=threat_intel.db
